# ==========================================
# MAI - SAJE LIMITED Configuration
# ==========================================

# ==========================================
# Application Settings
# ==========================================
NODE_ENV=production
PORT=3000
PORT_BACKEND=5000
APP_URL=https://mai-saje.com
APP_NAME="MAI - SAJE LIMITED"
APP_VERSION=1.0.0

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mai_saje_db
DB_USER=admin
DB_PASSWORD=secure_database_password_123
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Payment Gateway Integration
# ==========================================
# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_flutterwave_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public_key

# ==========================================
# Email Configuration (Nodemailer)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME="MAI - SAJE LIMITED"
SMTP_FROM_EMAIL=noreply@mai-saje.com

# ==========================================
# AWS S3 Configuration
# ==========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=mai-saje-bucket
AWS_REGION=us-east-1
AWS_S3_URL=https://mai-saje-bucket.s3.amazonaws.com

# ==========================================
# Redis Cache
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ==========================================
# Twilio SMS Configuration
# ==========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# Google Maps API
# ==========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ==========================================
# Security
# ==========================================
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_key
CORS_ORIGIN=https://mai-saje.com,https://www.mai-saje.com

# ==========================================
# Frontend URLs
# ==========================================
REACT_APP_API_URL=https://api.mai-saje.com
REACT_APP_PAYSTACK_KEY=pk_live_your_paystack_public_key
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key
